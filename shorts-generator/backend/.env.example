# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-xxxx
GEMINI_API_KEY=xxxx
# Google Cloud TTS는 서비스 계정 JSON 키 경로를 사용합니다
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# === 서버 설정 ===
PORT=4000

# === 무료 티어 쿼터 (하루 기준, 실제 정책은 수시로 바뀌니 대시보드에서 재확인) ===
NANOBANANA_DAILY_LIMIT=100
NANOBANANA_PRO_DAILY_LIMIT=2
TTS_MONTHLY_CHAR_LIMIT=1000000
